# ---- Database (Railway Postgres) ----
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/banqdrop"

# ---- Rails selection ----
# Which RailsProvider implementation to use. Phase 2 ships "mock".
# Swap to "oms" once OMS early-access keys arrive (factory line, not a refactor).
RAILS_PROVIDER="mock"

# Card issuer (see CARD.md):
#   "mock"      — dev, no vendor (default)
#   "bridge"    — Stripe Issuing + Bridge. US-capable, non-custodial, JIT from USDC.
#   "gnosispay" — ex-US (EU/UK/LATAM); Safe on Gnosis Chain, USDCe.
CARD_ISSUER="mock"
CARD_NETWORK="base"   # chain the card pulls USDC from (Bridge JIT)
# Stripe Issuing + Bridge — fill after onboarding (~6-8 wks):
# STRIPE_SECRET_KEY=
# STRIPE_ISSUING_WEBHOOK_SECRET=
# BRIDGE_API_KEY=

# ---- Chosen settlement chain (recorded Phase 1) ----
APP_CHAIN="polygon"
# USDC (native) on Polygon PoS:
USDC_CONTRACT="0x3c499c542cef5e3811e1192ce70d8cc03d5c3359"

# ---- OMS (primary — fill when early access granted) ----
OMS_API_TOKEN=""
OMS_WEBHOOK_SECRET=""
OMS_API_BASE="https://api.polygon.technology/oms"

# ---- Fallback rails (only if OMS rejected — see CLAUDE-base-stack.md) ----
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# ALCHEMY_API_KEY=
# ALCHEMY_WEBHOOK_SIGNING_KEY=
# MOONPAY_API_KEY=
# BRIDGE_API_KEY=

# ---- Mock provider (local dev) ----
# Shared secret to authenticate the mock deposit-trigger endpoint.
MOCK_WEBHOOK_SECRET="dev-mock-secret"
