// banqdrop — the bucket ledger (the moat). DB is accounting only:
// it never holds keys and never moves funds. Core invariant:
//   sum(bucket.amount) == on-chain USDC balance   (preserved on every path)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id // auth/rails user id
  walletAddress String    @unique
  chain         String    @default("polygon")
  email         String?   @unique
  kycStatus     String    @default("none") // none | pending | approved | rejected
  buckets       Bucket[]
  deposits      Deposit[]
  card          Card?
  createdAt     DateTime  @default(now())
}

// A card issued by a CardIssuer (mock now; Gnosis Pay later). The card draws from
// the user's isSpending bucket. Vendor-agnostic: provider + provider refs are stored
// so the issuer behind the CardIssuer contract can be swapped without schema change.
model Card {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String // "mock" | "gnosispay"
  providerCardId String
  last4          String
  brand          String   @default("visa")
  network        String   @default("gnosis") // settlement network the card spends on
  currency       String   @default("USDCe") // spendable token on that network
  status         String   @default("active") // issued | active | frozen | cancelled
  createdAt      DateTime @default(now())
}

model Bucket {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String // user-editable label (free-text, off-chain metadata)
  color      String
  pct        Int // share of inbound; per-user buckets must sum to 100
  amount     Decimal  @default(0) @db.Decimal(18, 2) // envelope balance (cents precision)
  isSpending Boolean  @default(false) // ROLE flag: "ready to spend" + card default. Decoupled from name.
  sortOrder  Int

  @@index([userId])
}

model Deposit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  txHash    String   @unique // dedupe key (holds unique event id; onchain = txHash:logIndex)
  amountUsd Decimal  @db.Decimal(18, 2)
  source    String // "oms" | "onchain" | "moonpay" | "bridge" | "mock"
  createdAt DateTime @default(now())

  @@index([userId])
}
